modules = ["nodejs-20", "python-3.11"]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[deployment]
router = "application"
deploymentTarget = "autoscale"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 29999
externalPort = 3001

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/zaiah-landing: web"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node artifacts/api-server/src/index.js"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/zaiah-landing: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 node artifacts/zaiah-landing/server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
